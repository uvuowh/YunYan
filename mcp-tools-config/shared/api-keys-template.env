# 🔑 MCP 工具链 API Keys 配置模板
# 复制此文件为 .env 并填入实际的 API Keys

# =================================
# Brave Search API Key (可选)
# =================================
# 获取地址: https://api.search.brave.com/
# 免费层: 每月 2000 次查询
# 用途: 网络搜索，查找最新技术信息和最佳实践
BRAVE_API_KEY=YOUR_BRAVE_API_KEY_HERE

# =================================
# 其他工具 API Keys (如需要)
# =================================

# Tavily Search API Key (Brave Search 的备选)
# 获取地址: https://tavily.com/
# TAVILY_API_KEY=YOUR_TAVILY_API_KEY_HERE

# OpenAI API Key (如果某些工具需要)
# 获取地址: https://platform.openai.com/api-keys
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# Anthropic API Key (如果某些工具需要)
# 获取地址: https://console.anthropic.com/
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# =================================
# 使用说明
# =================================

# 1. 复制此文件为 .env:
#    cp mcp-tools-config/shared/api-keys-template.env .env

# 2. 编辑 .env 文件，填入实际的 API Keys

# 3. 在 MCP 配置中引用环境变量:
#    "env": {
#      "BRAVE_API_KEY": "${BRAVE_API_KEY}"
#    }

# 4. 确保 .env 文件已添加到 .gitignore 中，避免泄露 API Keys

# =================================
# 注意事项
# =================================

# - 大部分 MCP 工具不需要额外的 API Keys
# - Brave Search API Key 是可选的，但推荐配置以获得更好的搜索体验
# - 请妥善保管你的 API Keys，不要提交到版本控制系统
# - 定期检查 API Key 的使用情况和有效期
