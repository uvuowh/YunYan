# Shrimp Task Manager Configuration
# 数据目录 - 存储任务数据、对话日志等信息
DATA_DIR=/Users/uvu/YunYan/.shrimp-task-manager/data

# 模板语言设置 - 支持 en (英文) 和 zh (中文)
TEMPLATES_USE=zh

# Web GUI 设置 - 是否启用 Web 界面
ENABLE_GUI=true

# 自定义提示词设置 (可选)
# MCP_PROMPT_PLAN_TASK=自定义任务规划指导...
# MCP_PROMPT_EXECUTE_TASK_APPEND=额外的执行指令...

# 日志级别
LOG_LEVEL=info

# 服务器端口 (如果启用 GUI)
GUI_PORT=3000
