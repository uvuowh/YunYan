{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YunYan",
  "version": "0.1.0",
  "identifier": "com.yunyan.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "YunYan",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "decorations": true,
        "alwaysOnTop": false,
        "fullscreen": false,
        "focus": true,
        "transparent": false,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "YunYan Team",
    "copyright": "Copyright © 2024 YunYan Team. All rights reserved.",
    "category": "Productivity",
    "shortDescription": "A modern desktop application built with Tauri and Vue",
    "longDescription": "YunYan is a powerful desktop application that demonstrates modern architecture patterns using Tauri, Vue 3, and TypeScript."
  }
}
